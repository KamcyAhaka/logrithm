rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User data ───────────────────────────────────────────────────────────
    // All user data is private — only the authenticated user may read/write.
    // /share/[username] reads via admin SDK which bypasses these rules safely.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Default deny ────────────────────────────────────────────────────────
    // Deny everything else. Never add a rule that allows public writes.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
