rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User data ───────────────────────────────────────────────────────────
    // All user data is private — only the authenticated user may read/write.
    // /share/[username] reads via admin SDK which bypasses these rules safely.

    // Insight history — readable if profile is public
    match /users/{uid}/insights/{insightId} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null && request.auth.uid == uid
        || get(/databases/$(database)/documents/users/$(uid)/profile/data).data.isPublic == true;
    }

    // Settings — private to owner only
    match /users/{uid}/settings/{document} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // The tokens/github doc now stores only a Secret Manager reference, never a raw token.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Share events — authenticated users can write, no client reads
    match /shareEvents/{eventId} {
      allow write: if request.auth != null;
      allow read: if false;
    }

    // Public slug lookup — readable by anyone, writable only by server
    match /slugs/{slug} {
      allow read: if true;
      allow write: if request.auth != null; // client writes on login
    }

    // ── Default deny ────────────────────────────────────────────────────────
    // Deny everything else. Never add a rule that allows public writes.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
