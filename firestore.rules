rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User data ───────────────────────────────────────────────────────────
    // All user data is private — only the authenticated user may read/write.
    // /share/[username] reads via admin SDK which bypasses these rules safely.

    // Insight history — readable if profile is public
    match /users/{uid}/insights/{insightId} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null && request.auth.uid == uid
        || get(/databases/$(database)/documents/users/$(uid)/profile/data).data.isPublic == true;
    }

    // Settings — private to owner only
    match /users/{uid}/settings/{document} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // User Profile data — publicly readable if profile is public
    match /users/{uid}/profile/data {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null && request.auth.uid == uid
        || resource.data.isPublic == true;
    }

    // Repository list — private to owner
    match /users/{uid}/repos/{repoId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // GitHub token reference document — private to owner
    match /users/{uid}/tokens/{tokenId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Snapshots — private to owner
    match /users/{uid}/snapshots/{snapshotId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Share events — authenticated users can write, no client reads
    match /shareEvents/{eventId} {
      allow write: if request.auth != null;
      allow read: if false;
    }

    // Public slug lookup — readable by anyone, writable only by server/owner
    match /slugs/{slug} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
    }

    // Anonymous leaderboard — server writes only, no client reads
    // (clients read aggregated /stats/ instead, never raw leaderboard)
    match /leaderboard/{entryId} {
      allow read, write: if false; // admin SDK only
    }

    // Aggregated stats — publicly readable, server writes only
    match /stats/{document=**} {
      allow read: if true;
      allow write: if false; // admin SDK only
    }

    // ── Default deny ────────────────────────────────────────────────────────
    // Deny everything else. Never add a rule that allows public writes.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
