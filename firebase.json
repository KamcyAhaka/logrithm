{
  "hosting": [
    {
      "site": "logrithm-ai",
      "public": "public",
      "cleanUrls": true,
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "**",
          "run": {
            "serviceId": "logrithm",
            "region": "us-central1"
          }
        }
      ]
    },
    {
      "site": "logrithm-ai-beta",
      "public": "public",
      "cleanUrls": true,
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "**",
          "run": {
            "serviceId": "logrithm-beta",
            "region": "us-central1"
          }
        }
      ]
    },
    {
      "site": "logrithm-ai-alpha",
      "public": "public",
      "cleanUrls": true,
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "**",
          "run": {
            "serviceId": "logrithm-alpha",
            "region": "us-central1"
          }
        }
      ]
    }
  ],
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log"],
      "predeploy": ["cd functions && bun run build"]
    }
  ],
  "firestore": [
    {
      "database": "(default)",
      "rules": "firestore.rules"
    },
    {
      "database": "dev-db",
      "rules": "firestore.rules"
    }
  ]
}
